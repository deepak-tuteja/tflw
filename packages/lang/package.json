{
  "name": "@tflw/lang",
  "version": "0.1.0",
  "private": true,
  "description": "testFlow language front-end — lexer, recursive-descent parser, AST, diagnostics. Pure, no I/O (SPEC §14).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": ["dist", "src", "GRAMMAR.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "pretest": "npm run docs:gen",
    "test:update": "UPDATE_GOLDEN=1 node --import tsx --test \"test/**/*.test.ts\"",
    "docs:gen": "node --import tsx scripts/gen-spec-tables.mjs"
  }
}
