{
  "name": "@tflw/reporter",
  "version": "0.1.0",
  "private": true,
  "description": "testFlow reporter — consumes the run report/event stream into a self-contained report.html, a CLI summary, and junit.xml.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@tflw/runtime": "*"
  }
}
