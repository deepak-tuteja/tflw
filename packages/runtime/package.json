{
  "name": "@tflw/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "testFlow runtime — interpreter over the AST, fetch binding, event stream, taint tracking. Playwright binding lands in M3.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-force-exit \"test/**/*.test.ts\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tflw/lang": "*",
    "ajv": "^8.17.1",
    "undici": "^8.7.0"
  }
}
