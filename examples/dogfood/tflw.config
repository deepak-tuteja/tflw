# Dogfood config: runs against the automationTestPOC sample api (sample-app/api on :3001).
# Secrets (admin credentials) come from the environment — a local .env is auto-loaded and its
# values are redacted from the report.

env local default
  api "http://localhost:3001"

# M2.6 (SPEC §3.3, P#42): a `session` block's steps run once per run; its `header` line becomes
# the header auto-applied to the api steps of any test running `as admin` — no more repeating the
# login-and-capture boilerplate that m2.5-features.tflw still does by hand via `before`.
session admin
  api POST /auth/login body { email: env(ADMIN_EMAIL), password: env(ADMIN_PW) }
  expect status equals 200
  capture body.token as token
  header "Authorization" is "Bearer {token}"

require env ADMIN_EMAIL, ADMIN_PW
