# External dogfood (PLAN.md decision 41): restful-booker (https://restful-booker.herokuapp.com) is
# a public QA-practice API we don't control — a more honest acceptance target than our own
# automationTestPOC sample app. Credentials here are the API's own publicly-documented test
# account (not a real secret), still routed through env(...)/.env like any other credential so the
# redaction path gets dogfooded too.

env booker default
  api "https://restful-booker.herokuapp.com"

session admin
  api POST /auth body { username: env(BOOKER_USER), password: env(BOOKER_PASS) }
  expect status equals 200
  capture body.token as token
  header "Cookie" is "token={token}"

require env BOOKER_USER, BOOKER_PASS
